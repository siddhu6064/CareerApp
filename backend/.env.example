# ══════════════════════════════════════════════════════════════════════
# [AppName] Backend — Environment Variables
# ══════════════════════════════════════════════════════════════════════
# Copy this file to backend/.env and fill in every value marked TODO.
# Never commit .env to git — it is in .gitignore.
#
# Render deployment: add each key via Dashboard → Environment → Add Variable
# Local dev: cp backend/.env.example backend/.env then fill in values
# ══════════════════════════════════════════════════════════════════════


# ── App mode ──────────────────────────────────────────────────────────
# saas   → Supabase + R2 + all external services
# desktop → SQLite only, no external services needed
APPNAME_MODE=saas


# ══════════════════════════════════════════════════════════════════════
# SUPABASE
# Dashboard → Project Settings → API
# ══════════════════════════════════════════════════════════════════════

# Project URL  (e.g. https://abcdefghijkl.supabase.co)
SUPABASE_URL=

# Service role key — has full DB access, bypasses RLS. Keep secret.
# Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_KEY=

# JWT secret — used to verify user tokens from the frontend.
# Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=


# ══════════════════════════════════════════════════════════════════════
# ANTHROPIC  (AI tailoring, cover letters, interview prep, parsing)
# console.anthropic.com → API Keys
# Set hard spend limit to $50/month in the dashboard.
# ══════════════════════════════════════════════════════════════════════

ANTHROPIC_API_KEY=


# ══════════════════════════════════════════════════════════════════════
# LEMONSQUEEZY  (billing — subscriptions, webhooks)
# app.lemonsqueezy.com → Settings → API
# ══════════════════════════════════════════════════════════════════════

# API key — Settings → API → Generate API key
LEMONSQUEEZY_API_KEY=

# Store ID — shown in your store's URL or Settings → Store
LEMONSQUEEZY_STORE_ID=

# Store slug — the subdomain of your LemonSqueezy store (e.g. "appname")
LEMONSQUEEZY_STORE_SLUG=appname

# Webhook signing secret — Webhooks → Add Webhook → Signing secret
# Webhook URL to register: https://api.appname.io/api/webhooks/lemonsqueezy
# Events to subscribe: subscription_created, subscription_updated,
#                      subscription_cancelled, subscription_expired,
#                      subscription_payment_failed
LEMONSQUEEZY_WEBHOOK_SECRET=

# Variant IDs — each plan + cadence combination gets its own variant ID.
# LemonSqueezy Dashboard → Products → [Product] → Variants → copy the ID.
# Pro plan: 7-day free trial on monthly variant (set in LS dashboard).
LEMONSQUEEZY_PRO_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PRO_ANNUAL_VARIANT_ID=
LEMONSQUEEZY_COACH_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_COACH_ANNUAL_VARIANT_ID=


# ══════════════════════════════════════════════════════════════════════
# RESEND  (transactional email — daily digest, welcome emails)
# resend.com → API Keys
# ══════════════════════════════════════════════════════════════════════

# API key — Dashboard → API Keys → Create API Key
RESEND_API_KEY=

# From address — must use your verified domain.
# Dashboard → Domains → Add Domain → verify DNS (SPF, DKIM, DMARC)
# Example: AppName <digest@appname.app>
RESEND_FROM=AppName <digest@appname.app>

# Webhook signing secret — for open/click/bounce tracking
# Dashboard → Webhooks → Add Endpoint → Signing Secret
# Endpoint URL: https://api.appname.io/api/webhooks/resend
# Events: email.sent, email.opened, email.clicked, email.bounced
RESEND_WEBHOOK_SECRET=


# ══════════════════════════════════════════════════════════════════════
# CLOUDFLARE R2  (resume PDF storage — zero egress)
# dash.cloudflare.com → R2 → Create Bucket
# ══════════════════════════════════════════════════════════════════════

# R2 endpoint — format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Account ID is in the Cloudflare dashboard right sidebar
R2_ENDPOINT=

# Bucket name (create it in the Cloudflare dashboard first)
R2_BUCKET=appname-resumes

# R2 API token credentials
# dash.cloudflare.com → R2 → Manage API Tokens → Create API Token
# Permissions: Object Read & Write on your bucket
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=


# ══════════════════════════════════════════════════════════════════════
# JOB SOURCES
# ══════════════════════════════════════════════════════════════════════

# JSearch (primary job source) — via RapidAPI
# rapidapi.com → search "JSearch" → Subscribe → copy X-RapidAPI-Key
JSEARCH_API_KEY=

# Adzuna (fallback job source)
# developer.adzuna.com → Create Account → My Apps → Create new app
ADZUNA_APP_ID=
ADZUNA_API_KEY=


# ══════════════════════════════════════════════════════════════════════
# INTERNAL SECURITY
# ══════════════════════════════════════════════════════════════════════

# Secret shared between GitHub Actions cron jobs and the backend.
# Any random 32+ char string — generate with: openssl rand -hex 32
# Add the same value to GitHub repo secrets as INTERNAL_SECRET.
X_INTERNAL_SECRET=


# ══════════════════════════════════════════════════════════════════════
# URLS
# ══════════════════════════════════════════════════════════════════════

# Public URL of the web app — used in email links, unsubscribe URLs.
# Local: http://127.0.0.1:3000  |  Production: https://app.appname.io
WEB_BASE_URL=https://app.appname.io


# ══════════════════════════════════════════════════════════════════════
# DEV / TEST TOGGLES
# Set to 1 to skip real API calls and use in-memory stubs.
# All default to 0 in production — only override locally or in CI.
# ══════════════════════════════════════════════════════════════════════

STUB_ANTHROPIC=0
STUB_JOBS_API=0
STUB_RESEND=0
STUB_EXPO_PUSH=0
STUB_LEMONSQUEEZY=0

# Set to 1 in tests to prevent APScheduler from starting
# APPNAME_DISABLE_SCHEDULER=0
