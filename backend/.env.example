# [AppName] backend environment.
# Copy to .env and fill in values for the mode you're running.

# ── Mode selection ────────────────────────────────────────────────
# saas (default) — multi-tenant cloud, requires Supabase
# desktop        — single-user local, requires nothing external
APPNAME_MODE=desktop

# ── Desktop mode ──────────────────────────────────────────────────
# Optional override — defaults to ~/.appname/
# APPNAME_DATA_DIR=/path/to/data

# ── SaaS mode (only required when APPNAME_MODE=saas) ──────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=
X_INTERNAL_SECRET=

# ── LLM (both modes; user-supplied in desktop via Settings UI) ────
ANTHROPIC_API_KEY=

# ── Dev toggles ───────────────────────────────────────────────────
STUB_ANTHROPIC=0
STUB_JOBS_API=0
STUB_LEMONSQUEEZY=1

# ── Billing (LemonSqueezy — SaaS only) ────────────────────────────────
# Get these from app.lemonsqueezy.com after creating your store + products
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_STORE_SLUG=appname
LEMONSQUEEZY_WEBHOOK_SECRET=
# Variant IDs — one per plan+cadence combination
LEMONSQUEEZY_PRO_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PRO_ANNUAL_VARIANT_ID=
LEMONSQUEEZY_COACH_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_COACH_ANNUAL_VARIANT_ID=
