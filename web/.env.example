# FastAPI backend URL — uvicorn defaults to 8000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Supabase (SaaS auth + Realtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_REALTIME_ENABLED=false

# Billing — LemonSqueezy variant IDs (public, safe to expose)
NEXT_PUBLIC_LS_PRO_MONTHLY_VARIANT_ID=
NEXT_PUBLIC_LS_PRO_ANNUAL_VARIANT_ID=
NEXT_PUBLIC_LS_COACH_MONTHLY_VARIANT_ID=
NEXT_PUBLIC_LS_COACH_ANNUAL_VARIANT_ID=
