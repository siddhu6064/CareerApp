{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AppName",
  "version": "0.1.0",
  "identifier": "com.appname.desktop",
  "build": {
    "beforeBuildCommand": "cd ../../web && npm run build:desktop",
    "beforeDevCommand": "cd ../../web && npm run dev",
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "AppName",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri://localhost; img-src 'self' tauri://localhost data: file:; style-src 'self' 'unsafe-inline'; script-src 'self' tauri://localhost; connect-src 'self' http://127.0.0.1:* tauri://localhost ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "AppName"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": ["binaries/appname-server"],
    "category": "Productivity",
    "shortDescription": "Job-search app with AI tailor + tracker",
    "longDescription": "AppName is a desktop job-search app: scrapes free public ATS boards, tailors your resume per job with your own Anthropic key, tracks applications through 8 stages, and generates ATS-optimised PDFs. BYOK — no subscription.",
    "publisher": "AppName",
    "copyright": "© 2026 AppName",
    "homepage": "https://appname.com",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist",
      "exceptionDomain": "127.0.0.1",
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English"]
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://desktop.appname.io/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": false,
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBKEY"
    }
  }
}
